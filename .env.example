# fastfish-hot 环境变量示例
# 复制为 .env 并填写

# ---------- 管理界面 ----------
HOT_ADMIN_API_KEY=your_api_key_here
HOT_API_HOST=0.0.0.0
HOT_API_PORT=8900

# ---------- 路径 ----------
# HOT_DB_PATH=data/fastfish_hot.db
# HOT_LOG_DIR=data/logs

# ---------- 数据源 ----------
HOT_API_BASE=https://api.pearktrue.cn

# ---------- 推送（Webhook/Token 仅存 .env，不存数据库）----------
# 飞书
# HOT_PUSH_FEISHU_WEBHOOK=https://open.feishu.cn/open-apis/bot/v2/hook/xxx

# 钉钉（机器人若开启加签，需配置 SECRET）
# HOT_PUSH_DINGTALK_WEBHOOK=https://oapi.dingtalk.com/robot/send?access_token=xxx
# HOT_PUSH_DINGTALK_SECRET=SECxxxxxxxx

# Telegram
# HOT_PUSH_TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
# HOT_PUSH_TELEGRAM_CHAT_ID=123456789

# 测试时绕过推送时间窗口（仅用于调试）
# HOT_PUSH_FORCE=1
